generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyType {
  CORE
  CUSTOMER
  SUPPLIER
  FLEET
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  PROCUREMENT
  OPERATION
  CUSTOMER
  SUPPLIER
  FLEET_OWNER
  DRIVER
  VIEWER
}

enum CreditStatus {
  NORMAL
  WATCH
  HOLD
  BLOCKED
}

model Company {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  taxId         String?       @map("tax_id")
  address       String?
  phone         String?
  email         String?
  bankName      String?       @map("bank_name")
  bankAccountNo String?       @map("bank_account_no")
  type          CompanyType
  status        CompanyStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  members               CompanyMember[]
  auditLogs             AuditLog[]
  customerSites         CustomerSite[]          @relation("CustomerCompanySites")
  customerCreditProfile CustomerCreditProfile?  @relation("CustomerCompanyCreditProfile")

  @@map("companies")
}

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String     @unique
  name      String?
  phone     String?
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  memberships    CompanyMember[]
  actorAuditLogs AuditLog[]      @relation("AuditLogActor")

  @@map("users")
}

model CompanyMember {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String     @map("company_id") @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_members")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  action      String
  field       String?
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  actorUser User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([companyId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

model CustomerSite {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerCompanyId     String   @map("customer_company_id") @db.Uuid
  siteName              String   @map("site_name")
  address               String
  province              String
  district              String
  subdistrict           String
  postalCode            String   @map("postal_code")
  gpsLat                Decimal? @map("gps_lat") @db.Decimal(10, 7)
  gpsLng                Decimal? @map("gps_lng") @db.Decimal(10, 7)
  contactName           String?  @map("contact_name")
  contactPhone          String?  @map("contact_phone")
  deliveryNote          String?  @map("delivery_note")
  accessRestriction     String?  @map("access_restriction")
  preferredDeliveryTime String?  @map("preferred_delivery_time")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  customerCompany Company @relation("CustomerCompanySites", fields: [customerCompanyId], references: [id], onDelete: Cascade)

  @@index([customerCompanyId])
  @@map("customer_sites")
}

model CustomerCreditProfile {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerCompanyId    String       @unique @map("customer_company_id") @db.Uuid
  creditLimit          Decimal      @default(0) @map("credit_limit") @db.Decimal(14, 2)
  creditTermDays       Int          @default(0) @map("credit_term_days")
  currentOutstanding   Decimal      @default(0) @map("current_outstanding") @db.Decimal(14, 2)
  overdueAmount        Decimal      @default(0) @map("overdue_amount") @db.Decimal(14, 2)
  creditStatus         CreditStatus @default(NORMAL) @map("credit_status")
  paymentBehaviorScore Int          @default(0) @map("payment_behavior_score")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  customerCompany Company @relation("CustomerCompanyCreditProfile", fields: [customerCompanyId], references: [id], onDelete: Cascade)

  @@map("customer_credit_profiles")
}
