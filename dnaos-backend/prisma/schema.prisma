generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CompanyType {
  CORE
  CUSTOMER
  SUPPLIER
  FLEET
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  LINE_LINKED
  SUSPENDED
}

enum IdentityProvider {
  LINE
}

enum SessionType {
  LINE
  SUPERADMIN
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  PROCUREMENT
  OPERATION
  CUSTOMER
  SUPPLIER
  FLEET_OWNER
  DRIVER
  VIEWER
}

enum CreditStatus {
  NORMAL
  WATCH
  HOLD
  BLOCKED
}

enum SupplierContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum DocumentGroupStatus {
  OPEN
  CLOSED
  ARCHIVED
}

enum DocumentType {
  ORD
  BOQ
  QT
  PO
  INV
  RCP
  PV
  PMT
}

enum DocumentReferenceRelationType {
  SOURCE
  PARENT
  CHILD
  GENERATED_FROM
  PAID_BY
  SETTLED_BY
}

model Company {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  taxId         String?       @map("tax_id")
  address       String?
  phone         String?
  email         String?
  bankName      String?       @map("bank_name")
  bankAccountNo String?       @map("bank_account_no")
  type          CompanyType
  status        CompanyStatus @default(ACTIVE)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  members               CompanyMember[]
  auditLogs             AuditLog[]
  customerSites         CustomerSite[]         @relation("CustomerCompanySites")
  customerCreditProfile CustomerCreditProfile? @relation("CustomerCompanyCreditProfile")
  supplierProducts      SupplierProduct[]      @relation("SupplierCompanyProducts")
  supplierContracts     SupplierContract[]     @relation("SupplierCompanyContracts")
  appSessions           AppSession[]
  projects              Project[]              @relation("CustomerCompanyProjects")
  documentGroups        DocumentGroup[]        @relation("CustomerCompanyDocumentGroups")

  @@map("companies")
}

model User {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String     @unique
  name      String?
  phone     String?
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  memberships    CompanyMember[]
  actorAuditLogs AuditLog[]      @relation("AuditLogActor")
  priceHistories PriceHistory[]  @relation("PriceHistoryChanger")
  identities     UserIdentity[]
  lineLinkTokens LineLinkToken[]
  appSessions    AppSession[]

  @@map("users")
}

model Admin {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  singletonKey Int        @unique @default(1) @map("singleton_key")
  username     String     @unique
  passwordHash String     @map("password_hash")
  email        String     @unique
  name         String
  phoneNumber  String?    @map("phone_number")
  role         Role       @default(ADMIN)
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  sessions AdminSession[]

  @@index([status])
  @@map("admins")
}

model AdminSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash")
  adminId          String    @map("admin_id") @db.Uuid
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  admin Admin @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([expiresAt])
  @@map("admin_sessions")
}

model UserIdentity {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  provider       IdentityProvider @default(LINE)
  providerUserId String           @map("provider_user_id")
  displayName    String?          @map("display_name")
  pictureUrl     String?          @map("picture_url")
  linkedAt       DateTime         @default(now()) @map("linked_at")
  lastLoginAt    DateTime?        @map("last_login_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
  @@map("user_identities")
}

model LineLinkToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("line_link_tokens")
}

model AppSession {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionTokenHash String      @unique @map("session_token_hash")
  userId           String      @map("user_id") @db.Uuid
  companyId        String      @map("company_id") @db.Uuid
  role             Role
  lineUserId       String      @map("line_user_id")
  sessionType      SessionType @default(LINE) @map("session_type")
  expiresAt        DateTime    @map("expires_at")
  revokedAt        DateTime?   @map("revoked_at")
  createdAt        DateTime    @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([expiresAt])
  @@map("app_sessions")
}

model CompanyMember {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String     @map("company_id") @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  role      Role
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([userId])
  @@map("company_members")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  companyId   String?  @map("company_id") @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  action      String
  field       String?
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  actorUser User?    @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([companyId])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_logs")
}

model CustomerSite {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerCompanyId     String   @map("customer_company_id") @db.Uuid
  siteName              String   @map("site_name")
  address               String
  province              String
  district              String
  subdistrict           String
  postalCode            String   @map("postal_code")
  gpsLat                Decimal? @map("gps_lat") @db.Decimal(10, 7)
  gpsLng                Decimal? @map("gps_lng") @db.Decimal(10, 7)
  contactName           String?  @map("contact_name")
  contactPhone          String?  @map("contact_phone")
  deliveryNote          String?  @map("delivery_note")
  accessRestriction     String?  @map("access_restriction")
  preferredDeliveryTime String?  @map("preferred_delivery_time")
  isActive              Boolean  @default(true) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  customerCompany Company @relation("CustomerCompanySites", fields: [customerCompanyId], references: [id], onDelete: Cascade)
  projects        Project[]

  @@index([customerCompanyId])
  @@map("customer_sites")
}

model Project {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectNo         String        @unique @map("project_no")
  customerCompanyId String        @map("customer_company_id") @db.Uuid
  customerSiteId    String        @map("customer_site_id") @db.Uuid
  title             String
  status            ProjectStatus @default(ACTIVE)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  customerCompany Company         @relation("CustomerCompanyProjects", fields: [customerCompanyId], references: [id], onDelete: Restrict)
  customerSite    CustomerSite    @relation(fields: [customerSiteId], references: [id], onDelete: Restrict)
  documentGroups  DocumentGroup[]

  @@index([customerCompanyId])
  @@index([customerSiteId])
  @@index([status])
  @@map("projects")
}

model DocumentGroup {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupNo           String              @unique @map("group_no")
  projectId         String              @map("project_id") @db.Uuid
  projectNo         String              @map("project_no")
  rootOrderId       String?             @map("root_order_id") @db.Uuid
  rootOrderNo       String?             @map("root_order_no")
  customerCompanyId String              @map("customer_company_id") @db.Uuid
  title             String
  status            DocumentGroupStatus @default(OPEN)
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  project         Project             @relation(fields: [projectId], references: [id], onDelete: Restrict)
  customerCompany Company             @relation("CustomerCompanyDocumentGroups", fields: [customerCompanyId], references: [id], onDelete: Restrict)
  references      DocumentReference[]

  @@index([projectId])
  @@index([projectNo])
  @@index([customerCompanyId])
  @@index([rootOrderNo])
  @@index([status])
  @@map("document_groups")
}

model DocumentReference {
  id                String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentGroupId   String?                       @map("document_group_id") @db.Uuid
  documentId        String                        @map("document_id")
  relatedDocumentId String                        @map("related_document_id")
  relationType      DocumentReferenceRelationType @map("relation_type")
  createdAt         DateTime                      @default(now()) @map("created_at")

  documentGroup DocumentGroup? @relation(fields: [documentGroupId], references: [id], onDelete: SetNull)

  @@unique([documentId, relatedDocumentId, relationType])
  @@index([documentGroupId])
  @@index([documentId])
  @@index([relatedDocumentId])
  @@index([relationType])
  @@map("document_references")
}

model CustomerCreditProfile {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerCompanyId    String       @unique @map("customer_company_id") @db.Uuid
  creditLimit          Decimal      @default(0) @map("credit_limit") @db.Decimal(14, 2)
  creditTermDays       Int          @default(0) @map("credit_term_days")
  currentOutstanding   Decimal      @default(0) @map("current_outstanding") @db.Decimal(14, 2)
  overdueAmount        Decimal      @default(0) @map("overdue_amount") @db.Decimal(14, 2)
  creditStatus         CreditStatus @default(NORMAL) @map("credit_status")
  paymentBehaviorScore Int          @default(0) @map("payment_behavior_score")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  customerCompany Company @relation("CustomerCompanyCreditProfile", fields: [customerCompanyId], references: [id], onDelete: Cascade)

  @@map("customer_credit_profiles")
}

model ProductCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([sortOrder])
  @@map("product_categories")
}

model Product {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  name        String
  description String?
  defaultUnit String   @map("default_unit")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category ProductCategory  @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  variants ProductVariant[]

  @@index([categoryId])
  @@index([isActive])
  @@map("products")
}

model ProductVariant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  name      String
  unit      String
  specs     Json     @default("{}")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product               Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  supplierProducts      SupplierProduct[]
  supplierContractItems SupplierContractItem[]

  @@index([productId])
  @@index([isActive])
  @@map("product_variants")
}

model SupplierProduct {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierCompanyId String   @map("supplier_company_id") @db.Uuid
  productVariantId  String   @map("product_variant_id") @db.Uuid
  sku               String?
  price             Decimal  @db.Decimal(14, 2)
  minQty            Decimal  @default(0) @map("min_qty") @db.Decimal(14, 3)
  serviceArea       String?  @map("service_area")
  leadTimeHours     Int      @default(0) @map("lead_time_hours")
  isAvailable       Boolean  @default(true) @map("is_available")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  supplierCompany Company        @relation("SupplierCompanyProducts", fields: [supplierCompanyId], references: [id], onDelete: Restrict)
  productVariant  ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([supplierCompanyId])
  @@index([productVariantId])
  @@index([isAvailable])
  @@map("supplier_products")
}

model SupplierContract {
  id                String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierCompanyId String                 @map("supplier_company_id") @db.Uuid
  contractNo        String                 @map("contract_no")
  startDate         DateTime               @map("start_date") @db.Date
  endDate           DateTime               @map("end_date") @db.Date
  paymentTermDays   Int                    @default(0) @map("payment_term_days")
  deliveryTerm      String?                @map("delivery_term")
  priceValidity     String?                @map("price_validity")
  status            SupplierContractStatus @default(DRAFT)
  createdAt         DateTime               @default(now()) @map("created_at")
  updatedAt         DateTime               @updatedAt @map("updated_at")

  supplierCompany Company                @relation("SupplierCompanyContracts", fields: [supplierCompanyId], references: [id], onDelete: Restrict)
  items           SupplierContractItem[]

  @@unique([supplierCompanyId, contractNo])
  @@index([supplierCompanyId])
  @@index([status])
  @@map("supplier_contracts")
}

model SupplierContractItem {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supplierContractId String   @map("supplier_contract_id") @db.Uuid
  productVariantId   String   @map("product_variant_id") @db.Uuid
  unitCost           Decimal  @map("unit_cost") @db.Decimal(14, 2)
  minQty             Decimal  @default(0) @map("min_qty") @db.Decimal(14, 3)
  maxQty             Decimal? @map("max_qty") @db.Decimal(14, 3)
  serviceArea        String?  @map("service_area")
  effectiveFrom      DateTime @map("effective_from") @db.Date
  effectiveTo        DateTime @map("effective_to") @db.Date
  createdAt          DateTime @default(now()) @map("created_at")

  supplierContract SupplierContract @relation(fields: [supplierContractId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant   @relation(fields: [productVariantId], references: [id], onDelete: Restrict)

  @@index([supplierContractId])
  @@index([productVariantId])
  @@index([effectiveFrom, effectiveTo])
  @@map("supplier_contract_items")
}

model PriceHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  oldPrice    Decimal? @map("old_price") @db.Decimal(14, 2)
  newPrice    Decimal  @map("new_price") @db.Decimal(14, 2)
  changedBy   String?  @map("changed_by") @db.Uuid
  reason      String?
  effectiveAt DateTime @map("effective_at")
  createdAt   DateTime @default(now()) @map("created_at")

  changedByUser User? @relation("PriceHistoryChanger", fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([changedBy])
  @@index([effectiveAt])
  @@map("price_histories")
}
