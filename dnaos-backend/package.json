{
  "name": "dnaos-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest --pool=threads",
    "db:generate": "prisma generate",
    "db:check": "tsx src/server/db/check.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed:admin": "tsx src/server/db/seedAdmin.ts",
    "db:seed:superadmin": "tsx src/server/db/seedAdmin.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.53.1",
    "@supabase/supabase-js": "^2.106.1",
    "date-fns": "^4.2.1",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "inngest": "^4.4.0",
    "pg": "^8.21.0",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "prisma": "^7.8.0",
    "supabase": "^2.100.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
